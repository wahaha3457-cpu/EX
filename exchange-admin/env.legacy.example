# 已与 .env.development 默认一致；仅在你想用 .env.local 覆盖时参考。
# 复制为 .env.local 可覆盖任意变量（修改后重启 npm run dev）。

VITE_USE_MOCK=false
VITE_AUTH_PROVIDER=legacy
VITE_LEGACY_API_BASE=/legacy-api
VITE_LEGACY_TICKER_PATH=/api/publicRealtimeTop
VITE_LEGACY_TICKER_TYPE=cryptos
