VITE_APP_TITLE=Exchange
VITE_API_BASE=/api
# 访问主站 /admin/* 时浏览器跳转到独立运营后台（另见仓库 exchange-admin，npm run dev，默认 5174）
VITE_ADMIN_PORTAL_URL=http://127.0.0.1:5174
#
# 当前默认：联调 bian50test（真实登录 + 行情 REST）。无需再配 .env.local。
# 改回「纯前端假数据」：设 VITE_USE_MOCK=true，并删掉或注释 VITE_AUTH_PROVIDER。
# 修改后务必重启 npm run dev。
#

# false = 登录/行情走真实接口；true = 全部 Mock（离线演示）
VITE_USE_MOCK=false
# 全球资讯：mock=仅演示稿；不设则优先 CoinDesk RSS（需 dev 代理 /coindesk-rss 或生产网关同源转发）
# VITE_NEWS_FEED=mock
# VITE_COINDESK_RSS_URL=https://your-cdn.example.com/coindesk-rss.xml
#
# 全站行情列表：binance（默认）| legacy | server；现货条数默认 268，另附 U 本位永续 Top 40
VITE_MARKET_TICKERS_SOURCE=server
# 现货交易 REST：默认在 MARKET_TICKERS_SOURCE=server 且 VITE_AUTH_PROVIDER=exchange 时已走 /api/v1/spot/*（下单/撤单/余额）
# 若行情仍用 binance 但要接 exchange-server 现货，可单独开启：VITE_SPOT_TRADING_API=exchange
# VITE_BINANCE_SPOT_TOP=268
# VITE_BINANCE_FUTURES_TOP=40
VITE_AUTH_PROVIDER=exchange
VITE_LEGACY_API_BASE=/legacy-api

# 行情列表（仍空可改为 publicNewRealtimeByType + SUBTYPE，见下方注释）
VITE_LEGACY_TICKER_PATH=/api/publicRealtimeTop
VITE_LEGACY_TICKER_TYPE=cryptos

# VITE_LEGACY_TICKER_PATH=/api/publicNewRealtimeByType
# VITE_LEGACY_TICKER_TYPE=cryptos
# VITE_LEGACY_TICKER_SUBTYPE=usdt

# 以下为可选覆盖（默认已与 Swagger 对齐）
# VITE_LEGACY_PATH_LOGIN=/api/login
# VITE_LEGACY_PATH_REGISTER_NO_VERIFY=/api/registerNoVerifcode
# VITE_LEGACY_PATH_REGISTER_WITH_VERIFY=/api/registerVerifcode
# VITE_LEGACY_PATH_SEND_CODE=/api/idcode/execute
# VITE_LEGACY_KLINE_PATH=/api/hobi!getKline.action
#
# Legacy 现货交易（Swagger「现货交易API」）：默认已对齐 hobi 行情/深度/成交 + exchangeapplyorder 下单/列表/撤单 + assets 余额
# VITE_LEGACY_SPOT_REALTIME=/api/hobi!getRealtime.action
# VITE_LEGACY_SPOT_DEPTH=/api/hobi!getDepth.action
# VITE_LEGACY_SPOT_TRADES=/api/hobi!getStockTradeList.action
# VITE_LEGACY_SPOT_OPENVIEW=/api/exchangeapplyorder!openview.action
# VITE_LEGACY_SPOT_OPEN=/api/exchangeapplyorder!open.action
# VITE_LEGACY_SPOT_ORDER_LIST=/api/exchangeapplyorder!list.action
# VITE_LEGACY_SPOT_ORDER_HISTORY=/api/exchangeapplyorder!otherList.action
# VITE_LEGACY_SPOT_CANCEL=/api/exchangeapplyorder!cancel.action
# VITE_LEGACY_SPOT_ASSETS=/api/assets!getAll.action
# VITE_LEGACY_SPOT_MARKET_TYPE=cryptos
#
# 首页公告（H5 通知列表，与 Knife4j 一致时可拉到真实公告）
# VITE_LEGACY_NOTICE_LIST_PATH=/api/notice/list
#
# Legacy 合约（见 src/api/contract/legacy/）：默认对齐 contractApplyOrder / contractOrder / futuresOrder / hobi
# VITE_LEGACY_FUTURES_OPENVIEW=/api/contractApplyOrder!openview.action
# VITE_LEGACY_FUTURES_OPEN=/api/contractApplyOrder!open.action
# VITE_LEGACY_FUTURES_CLOSE=/api/contractApplyOrder!close.action
# VITE_LEGACY_FUTURES_CANCEL=/api/contractApplyOrder!cancel.action
# Legacy 资产中心（见 src/api/asset/legacy/legacyAssetsCenter.ts）
# VITE_LEGACY_WALLET_SUM_ASSETS=/api/wallet/getNewAllSumAndAssets.action
# VITE_LEGACY_WALLET_ALL_BALANCE=/api/wallet/getAllWalletBalance

# 配置后现货/合约页使用真实 WS；不配置则继续本地 mock 定时流
# VITE_WS_PUBLIC_URL=wss://example.com/ws/public
# VITE_WS_PRIVATE_URL=wss://example.com/ws/private
